ENVIRONMENT=development
DEBUG=true

# Generate a dev keypair with: uv run python scripts/generate_jwt_keypair.py
# Required (app refuses to start without them) in staging/production.
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# Change these before deploying anywhere beyond a local machine.
SECRET_KEY=insecure-development-only-change-me
S3_SECRET_KEY=insecure-development-only-change-me

DATABASE_URL=postgresql+asyncpg://arutech:arutech@localhost:5432/arutech
REDIS_URL=redis://localhost:6379/0

CORS_ORIGINS=["http://localhost:3000"]

# IPs/CIDR ranges allowed to set X-Forwarded-For (default: loopback only).
# docker-compose.yml raises this to the compose network's subnet, since the
# web app's BFF (Phase 4) and nginx both call this API from inside it.
TRUSTED_PROXY_IPS=["127.0.0.1"]

# Left unset for bare-metal/host dev on purpose: spans are still created
# (instrumentation still runs) but not exported anywhere unless this is
# set, which is the right default outside Docker. docker-compose.yml sets
# it to http://otel-collector:4317 for the containerized api/worker
# services specifically; the collector's port isn't published to the host,
# so pointing a host-run process at localhost:4317 would just fail here.
OTEL_EXPORTER_OTLP_ENDPOINT=

S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=arutech
S3_BUCKET_NAME=arutech-documents
